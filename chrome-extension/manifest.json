{
  "manifest_version": 3,
  "name": "OPC UA Address Space Browser",
  "version": "1.0.0",
  "description": "Browse OPC UA address space from the InterSystems IRIS Management Portal",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": [
        "http://*/*/csp/sys/%25CSP.Portal.Home.zen*",
        "https://*/*/csp/sys/%25CSP.Portal.Home.zen*",
        "http://*/csp/sys/%25CSP.Portal.Home.zen*",
        "https://*/csp/sys/%25CSP.Portal.Home.zen*"
      ],
      "css": ["content/content.css"],
      "js": [
        "content/api-client.js",
        "content/config-panel.js",
        "content/node-detail.js",
        "content/tree-browser.js",
        "content/content-panel.js",
        "content/sidebar-injector.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  }
}
